{
    default_bind 0.0.0.0
}

voxtranslate.loftestudios.com {

    handle /api/jobs/*/events {
        reverse_proxy backend:8000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy frontend:3000
    }

    log {
        output stdout
        format console
    }
}
